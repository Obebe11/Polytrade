# ─────────────────────────────────────────────────
#  .env — конфигурация Polymarket Bot
#  ВАЖНО: никогда не добавляйте этот файл в git!
# ─────────────────────────────────────────────────

# Приватный ключ вашего Polygon-кошелька (EOA)
# Формат: 0x + 64 hex символа
PRIVATE_KEY=0xВАШ_ПРИВАТНЫЙ_КЛЮЧ_ЗДЕСЬ

# API-ключи Polymarket (можно оставить пустыми —
# бот сам деривирует их из приватного ключа при первом запуске)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Размер портфеля в USD (используется для расчёта риска)
# Обновляйте вручную или бот попытается получить баланс из API
PORTFOLIO_VALUE=100
